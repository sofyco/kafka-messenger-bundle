{
    "name": "sofyco/kafka-messenger-bundle",
    "type": "symfony-bundle",
    "version": "3.0.1",
    "description": "Symfony Kafka Messenger Bundle",
    "keywords": ["php", "symfony", "bundle", "kafka", "messenger"],
    "homepage": "https://github.com/sofyco/kafka-messenger-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Sofiia Korzhova",
            "email": "sofykorzhova@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "ext-rdkafka": "*",
        "symfony/framework-bundle": "^8.0",
        "symfony/messenger": "^8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.1"
    },
    "autoload": {
        "psr-4": {
            "Sofyco\\Bundle\\KafkaMessengerBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sofyco\\Bundle\\KafkaMessengerBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true
    }
}
